# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero setup - file auto-created as gramco.db)
DATABASE_URL=sqlite:///./gramco.db

# To use PostgreSQL instead:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/gramco

# ── Groq AI ───────────────────────────────────────────────────────────────────
# Obtain your key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Recommended models: llama-3.3-70b-versatile | llama-3.1-8b-instant | gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
