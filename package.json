{
  "name": "gramco",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"API,UI\" -c \"bgBlue.bold,bgGreen.bold\" --kill-others-on-fail \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "cd backend && python -m uvicorn app.main:app --reload --port 8000",
    "dev:ui": "npm run dev --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
